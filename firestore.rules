rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /households/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // GrowthOS sync — users can read/write their own growthOS data
    // WealthOS writes wealthSnapshot here; GrowthOS reads it.
    match /users/{userId}/growthOS/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Feedback collection - users can create and read their own, admin can read/write all
    match /feedback/{feedbackId} {
      // Anyone authenticated can create feedback
      allow create: if request.auth != null;
      
      // Users can read their own feedback, admin can read all
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.email == "abhav.aanya@gmail.com");
      
      // Admin can update any, users can only update their own (for marking read)
      allow update: if request.auth != null && 
        (request.auth.token.email == "abhav.aanya@gmail.com" ||
         resource.data.userId == request.auth.uid);
      
      // Only admin can delete feedback
      allow delete: if request.auth != null && 
        request.auth.token.email == "abhav.aanya@gmail.com";
    }
    
    // Notifications collection — admin sends, all authenticated users read
    match /notifications/{notificationId} {
      // Any authenticated user can read notifications
      allow read: if request.auth != null;
      
      // Any authenticated user can update (for marking as read via readBy array)
      allow update: if request.auth != null;
      
      // Only admin can create notifications
      allow create: if request.auth != null && 
        request.auth.token.email == "abhav.aanya@gmail.com";
      // Any authenticated user can delete (dismiss for themselves, admin full delete)
      allow delete: if request.auth != null;
    }
  }
}
