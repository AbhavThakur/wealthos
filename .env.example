# Copy this file to .env.local and fill in your Firebase project values.
# Get these from Firebase Console → Project Settings → Your apps → Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "dev" to use isolated dev_ prefixed collections in Firestore.
# Leave empty or "prod" for production data.
VITE_ENV=dev

# Admin email — this user gets access to backups, restore, dev tools,
# salary data import, and the danger zone (reset all data).
# Leave empty to hide admin features from all users.
VITE_ADMIN_EMAIL=

# Gemini AI Advisor — get a free API key at https://aistudio.google.com
# Free tier: 15 RPM on Gemini 2.0 Flash — more than enough for personal use.
VITE_GEMINI_KEY=
